{
  "build": {
    "env": {
      "NODE_VERSION": "20.x"
    }
  },
  "crons": [
    {
      "path": "/api/cron/brevard-brief",
      "schedule": "30 12 * * 1"
    },
    {
      "path": "/api/cron/permian-brief",
      "schedule": "40 12 * * 1"
    },
    {
      "path": "/api/cron/brevard-submarket-watch",
      "schedule": "50 12 * * 1"
    },
    {
      "path": "/api/cron/brevard-fund-landscape",
      "schedule": "0 13 * * 1"
    },
    {
      "path": "/api/cron/permian-submarket-watch",
      "schedule": "10 13 * * 1"
    },
    {
      "path": "/api/cron/permian-fund-landscape",
      "schedule": "20 13 * * 1"
    },
    {
      "path": "/api/cron/ir-inbox-sweep",
      "schedule": "*/5 13-23,0-2 * * *"
    },
    {
      "path": "/api/ir-kb-sync",
      "schedule": "30 13 * * 0"
    },
    {
      "path": "/api/cron/ir-qa-update",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/ir-draft-outcomes",
      "schedule": "45 */2 * * *"
    },
    {
      "path": "/api/cron/ir-sent-log",
      "schedule": "*/30 13-23,0-2 * * *"
    },
    {
      "path": "/api/cron/doc-extract",
      "schedule": "15 */6 * * *"
    },
    {
      "path": "/api/cron/loopnet-sync",
      "schedule": "0 14 * * 1"
    },
    {
      "path": "/api/lp-directory",
      "schedule": "0 12 * * 1"
    }
  ]
}
