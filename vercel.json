{
  "build": {
    "env": {
      "NODE_VERSION": "20.x"
    }
  },
  "crons": [
    {
      "path": "/api/cron/brevard-brief",
      "schedule": "30 12 * * 1"
    },
    {
      "path": "/api/cron/permian-brief",
      "schedule": "40 12 * * 1"
    },
    {
      "path": "/api/cron/brevard-submarket-watch",
      "schedule": "50 12 * * 1"
    },
    {
      "path": "/api/cron/brevard-fund-landscape",
      "schedule": "0 13 * * 1"
    },
    {
      "path": "/api/cron/permian-submarket-watch",
      "schedule": "10 13 * * 1"
    },
    {
      "path": "/api/cron/permian-fund-landscape",
      "schedule": "20 13 * * 1"
    }
  ]
}
